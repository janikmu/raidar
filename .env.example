# Copy to .env and fill in. .env is gitignored.

# Academic OpenAI-compatible proxy (Mistral Small 4, GPT-OSS 120B, etc.)
ACADEMIC_API_KEY=
ACADEMIC_BASE_URL=

# GitHub PAT (read-only public_repo scope is enough). Optional but strongly recommended:
# unauthenticated GitHub API is 60 req/hour; with a PAT it's 5000/hour.
GITHUB_PAT=

# LMStudio (chat + embeddings; default port 1234).
# Load both a chat model (config.yaml: providers.local-lmstudio.model) and an
# embedding model (config.yaml: embeddings.model) in LMStudio — its OpenAI server
# routes by the `model` field in each request.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
