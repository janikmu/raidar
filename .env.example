# Copy to .env and fill in. .env is gitignored.

# Academic OpenAI-compatible proxy (gpt-oss-120b, mistral-small-4-119b-2603, e5-mistral-7b-instruct)
ACADEMIC_API_KEY=
ACADEMIC_BASE_URL=

# GitHub PAT (read-only public_repo scope is enough). Optional but strongly recommended:
# unauthenticated GitHub API is 60 req/hour; with a PAT it's 5000/hour.
GITHUB_PAT=

# Local backends (LMStudio default port is 1234, Ollama is 11434).
# Override here only if you bind to non-default ports.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
OLLAMA_BASE_URL=http://localhost:11434
